  <!--==============================
    Blog Area
==============================-->
 <section class="vs-blog-wrapper blog-details space-top space-extra-bottom">
  <div class="container">
    <div class="row">
      <div class="col-xl-12 col-lg-12">
        <div class="vs-blog blog-single">

          <div class="blog-img mb-60 wow animate__fadeInUp" data-wow-delay="0.35s">

            <img class="blog-details-img" src="/uploads/<%= blog.imageUrl %>" alt="<%= blog.title %>">

            <div class="blog-tag"><%= blog.title %></div>

            <div class="blog-meta">
              <a href="#"><i class="fas fa-calendar-alt"></i>
                <%= new Date(blog.createdAt).toLocaleDateString('en-GB',{day:'2-digit',month:'long',year:'numeric'}) %>
              </a>

              <a href="#"><i class="fa-solid fa-user"></i>By <%= blog.author %></a>

              <a href="#"><i class="fas fa-folder-open"></i>Education</a>
            </div>

          </div>

          <div class="blog-content">

            <h2 class="blog-title wow animate__fadeInUp" data-wow-delay="0.35s">
              <%= blog.title %>
            </h2>

            <div class="blog-text wow animate__fadeInUp" data-wow-delay="0.35s">
              <%- blog.content %>
            </div>

            <div class="share-links wow animate__fadeInUp" data-wow-delay="0.35s">
              <div class="row align-items-center">
                <div class="col-xl-6 col-lg-auto">
                  <div class="tagcloud">
                    <span class="share-links-title">Tags:</span>

                    <% if(blog.metaKeywords){ %>
                      <% blog.metaKeywords.forEach(tag => { %>
                        <a href="#"><%= tag %></a>
                      <% }) %>
                    <% } %>

                  </div>
                </div>
              </div>
            </div>

          </div>

        </div>
      </div>
    </div>
  </div>
</section>
  <!--==============================
    Blog Area End
    ==============================-->

