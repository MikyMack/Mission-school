            Upcoming Events
            <img src="/img/shapes/right-title-shape.svg" alt="shape">
          </span>
          <h2 class="sec-title text-title title-anime__title">
            Discover Our <span class="title-highlight text-secondary inline">Exciting Events</span>
          </h2>
        </div>
      </div>
    </div>

    <div class="row">
      <div class="col-12">
         <div class="d-flex justify-content-end align-items-center mb-3 events-arrows">
    <button class="icon-btn2" data-slick-prev=".events-slider">
      <i class="fal fa-long-arrow-left"></i>
    </button>
    <button class="icon-btn2" data-slick-next=".events-slider">
      <i class="fal fa-long-arrow-right"></i>
    </button>
  </div>
        <div class="events-slider vs-carousel wow animate__fadeInUp" data-wow-delay="0.3s" 
             data-slide-show="3" 
             data-lg-slide-show="3" 
             data-md-slide-show="2" 
             data-sm-slide-show="1" 
             data-arrows="true">

          <% events.forEach(event => { %>
          <div class="event-slide">
            <div class="event-card">
              <div class="event-image">
                <img src="/uploads/<%= event.image %>" alt="<%= event.title %>">
                <div class="event-date">
                  <span class="day"><%= new Date(event.date).getDate() %></span>
                  <span class="month"><%= new Date(event.date).toLocaleString('default', { month: 'short' }) %></span>
                </div>
              </div>
              <div class="event-content">
                <div class="event-meta">
                  <% if(event.time) { %>
                    <span><i class="far fa-clock"></i> <%= event.time %></span>
                  <% } %>
                  <% if(event.eventPlace) { %>
                    <span><i class="fas fa-map-marker-alt"></i> <%= event.eventPlace %></span>
                  <% } %>
                </div>
                <h3 class="event-title"><%= event.title %></h3>
                <p class="event-description"><%= event.description %></p>
              </div>
            </div>
          </div>
          <% }) %>

        </div>
      </div>
    </div>

    <div class="text-center">
      <a href="/events" class="vs-btn">View All Events <i class="fas fa-arrow-right"></i></a>
    </div>
  </div>
</section>
  <!-- Events Area End -->

