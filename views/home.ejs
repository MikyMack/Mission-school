<section class="hero-layout1 hero-slider" data-wow-delay="0.25s" aria-hidden="true">
  <div class="hero-slider-wrapper">
    <% banners.forEach((banner, index) => { %>
      <div class="hero-slide" style="background-image: url('/uploads/<%= banner.image %>');">
        <div class="hero-item">
          <div class="container position-relative z-index">
            <div class="row">
              <div class="col-lg-8 position-relative">
                <div class="hero-content">
                  <% if (banner.title) { %>
                    <div class="hero-subtitle wow animate__fadeInUp" data-wow-delay="0.30s">
                      <%= banner.title %>
                    </div>
                  <% } %>

                  <% if (banner.subtitle) { %>
                    <h1 class="hero-title wow animate__fadeInUp" data-wow-delay="0.50s">
                      <%= banner.subtitle %>
                    </h1>
                  <% } %>

                  <% if (banner.description) { %>
                    <p class="hero-text wow animate__fadeInUp" data-wow-delay="0.75s">
                      <%= banner.description %>
                    </p>
                  <% } %>

                  <% if (banner.link) { %>
                    <a class="vs-btn wow animate__fadeInUp" data-wow-delay="0.95s" href="<%= banner.link %>">
                      Learn More <i class="fa-regular fa-arrow-right"></i>
                    </a>
                  <% } %>

                  <span class="dot-shape wow animate__bounceInRight" data-wow-delay="0.70s"></span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% }) %>
  </div>

  <!-- Slider Controls -->
  <div class="hero-slider-controls">
    <button class="hero-slider-prev"><i class="fas fa-chevron-left"></i></button>
    <button class="hero-slider-next"><i class="fas fa-chevron-right"></i></button>
  </div>
</section>
