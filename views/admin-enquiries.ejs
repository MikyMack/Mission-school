<!-- admin-enquiries.ejs -->
<div class="main-content">
    <div class="main-content-inner">
        <div class="main-content-wrap">
            <div class="flex items-center flex-wrap justify-between gap20 mb-30">
                <h3>Admission Enquiries</h3>
                <ul class="breadcrumbs flex items-center flex-wrap justify-start gap10">
                    <li>
                        <a href="/admin/admin-dashboard"><div class="text-tiny">Dashboard</div></a>
                    </li>
                    <li>
                        <i class="icon-chevron-right"></i>
                    </li>
                    <li>
                        <div class="text-tiny">Enquiries</div>
                    </li>
                </ul>
            </div>

            <div class="wg-box">
                <div class="flex items-center justify-between gap10 flex-wrap">
                    <div class="wg-filter flex-grow">
                        
                        <form class="form-search" id="searchForm">
                            <fieldset class="name">
                                <input type="text" placeholder="Search here..." class="search-input"
                                    name="search" id="searchInput" tabindex="2" value=""
                                    aria-required="true">
                            </fieldset>
                            <div class="button-submit">
                                <button class="" type="submit"><i class="icon-search"></i></button>
                            </div>
                        </form>
<select id="statusFilter">
  <option value="all" <%= selectedStatus === "all" ? "selected" : "" %>>All</option>
  <option value="new" <%= selectedStatus === "new" ? "selected" : "" %>>New</option>
  <option value="contacted" <%= selectedStatus === "contacted" ? "selected" : "" %>>Contacted</option>
</select>
                    </div>
                </div>

                <div class="wg-table table-all-category">
                    <ul class="table-title enquiry-grid enquiry-header mb-14">
                        <li style="flex: 2;"><div class="body-title">Parent Name</div></li>
                        <li style="flex: 2;"><div class="body-title">Student Name</div></li>
                        <li style="flex: 1;"><div class="body-title">Email</div></li>
                        <li style="flex: 1;"><div class="body-title">Phone</div></li>
                        <li style="flex: 1;"><div class="body-title">Grade</div></li>
                        <li style="flex: 2;"><div class="body-title">Message</div></li>
                        <li style="flex: 1;"><div class="body-title">Status</div></li>
                        <li style="flex: 1;"><div class="body-title">Action</div></li>
                    </ul>

                    <ul class="flex flex-column" id="enquiriesList">
                        <% if (enquiries && enquiries.length > 0) { %>
                            <% enquiries.forEach(enquiry => { %>
                                <li class="wg-product enquiry-grid enquiry-row" id="enquiry-<%= enquiry._id %>">
                                    <div class="parent-name body-text text-main-dark mt-4" style="flex: 2;"><%= enquiry.parentName %></div>
                                    <div class="student-name body-text text-main-dark mt-4" style="flex: 2;"><%= enquiry.studentName || '-' %></div>
                                    <div class="email body-text text-main-dark mt-4" style="flex: 1;"><%= enquiry.email %></div>
                                    <div class="phone body-text text-main-dark mt-4" style="flex: 1;"><%= enquiry.phone %></div>
                                    <div class="grade body-text text-main-dark mt-4" style="flex: 1;"><%= enquiry.grade || '-' %></div>
                                    <div class="message body-text text-main-dark mt-4" style="flex: 2;"><%= enquiry.message || '-' %></div>
                                    <div style="flex: 1;">
                                        <div class="toggle-container">
                                       <select 
                                        class="enquiry-drop status-<%= enquiry.status %>" 
                                        onchange="updateEnquiryStatus('<%= enquiry._id %>', this.value, this)"
                                        style="width:auto;"
                                        >
                                        <option value="new" <%= enquiry.status === 'new' ? 'selected' : '' %>>New</option>
                                        <option value="contacted" <%= enquiry.status === 'contacted' ? 'selected' : '' %>>Contacted</option>
                                        </select>
                                        </div>
                                    </div>
                                    <div class="list-icon-function" style="flex: 1;">
                                        <div class="item trash" onclick="confirmDeleteEnquiry('<%= enquiry._id %>')">
                                            <i class="icon-trash-2"></i>
                                        </div>
                                    </div>
                                </li>
                            <% }); %>
                        <% } else { %>
                            <div class="no-banners">
                                <p>No enquiries found</p>
                            </div>
                        <% } %>
                    </ul>
