                <div class="divider"></div>
                <div class="flex items-center justify-between flex-wrap gap10">
                    <ul class="wg-pagination">
                    <% for(let i = 1; i <= totalPages; i++) { %>

                        <li>
                        <a href="/admin/admin-enquiries?page=<%= i %>"
                            class="<%= currentPage === i ? 'active' : '' %>">
                            <%= i %>
                        </a>
                        </li>

                    <% } %>
                    </ul>
                </div>
            </div>
