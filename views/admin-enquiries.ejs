<script>
    // Toggle status (new <-> contacted)
async function updateEnquiryStatus(id, newStatus, element) {

  try {

    const response = await fetch(`/admin/enquiries/${id}`, {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({ status: newStatus })
    });

    const data = await response.json();

    if (!response.ok) {
      throw new Error(data.message || "Failed to update status");
    }

    alert("Status updated successfully");

    element.classList.remove("status-new", "status-contacted");
    element.classList.add(`status-${newStatus}`);

  } catch (error) {

    console.error(error);
    alert(error.message || "Server error");

  }

}

// Delete enquiry
    function confirmDeleteEnquiry(id) {
    if (confirm("Are you sure you want to delete this enquiry?")) {
        deleteEnquiry(id);
    }
    }

    async function deleteEnquiry(id) {
    try {
        const response = await fetch(`/admin/enquiries/${id}`, {
        method: "DELETE"
        });

        const result = await response.json();

        if (!response.ok) {
        throw new Error(result.message || "Failed to delete enquiry");
        }

        alert("Enquiry deleted successfully");

        const row = document.getElementById(`enquiry-${id}`);
        if (row) row.remove();

    } catch (error) {
        console.error("Delete Error:", error);
        alert(error.message || "Server error while deleting enquiry");
    }
    }
    
// Search functionality
    document.getElementById('searchForm').addEventListener('submit', function(e) {
        e.preventDefault();
        const searchTerm = document.getElementById('searchInput').value.toLowerCase();
        document.querySelectorAll('#enquiriesList li.wg-product').forEach(enquiry => {
            const parentName = enquiry.querySelector('div[style*="flex: 2"]').textContent.toLowerCase();
            if (parentName.includes(searchTerm)) {
                enquiry.style.display = 'flex';
            } else {
                enquiry.style.display = 'none';
            }
        });
    });

    function updatePagination() {
        const entriesPerPage = document.getElementById('entriesPerPage').value;
        console.log(`Show ${entriesPerPage} entries per page`);
    }

document.getElementById("searchForm").addEventListener("submit", function (e) {
  e.preventDefault();

  const searchValue = document
    .getElementById("searchInput")
    .value
    .trim()
    .toLowerCase();

  const rows = document.querySelectorAll("#enquiriesList .item-row");

  rows.forEach(row => {

    const parent = row.querySelector(".parent-name")?.innerText.toLowerCase() || "";
    const student = row.querySelector(".student-name")?.innerText.toLowerCase() || "";
    const email = row.querySelector(".email")?.innerText.toLowerCase() || "";
    const phone = row.querySelector(".phone")?.innerText.toLowerCase() || "";
    const grade = row.querySelector(".grade")?.innerText.toLowerCase() || "";

    const searchableText = `${parent} ${student} ${email} ${phone} ${grade}`;

    row.style.display = searchableText.includes(searchValue) ? "flex" : "none";

  });
});

document.getElementById("statusFilter").addEventListener("change", function () {

  const status = this.value;

  const url = new URL(window.location.href);
  url.searchParams.set("status", status);
  url.searchParams.set("page", 1);

  window.location.href = url.toString();

});

</script>
