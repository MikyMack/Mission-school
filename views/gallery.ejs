  <!-- Gallery area Start -->
  <section class="gallery-layout3 space-top space-extra-bottom">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-xl-6 col-lg-7 col-auto">
          <div class="title-area text-center mt-n1 animation-style1 title-anime">
            <span class="sec-subtitle text-theme title-anime__title"><img src="/img/shapes/left-title-shape.svg" alt="shape">Gallery<img src="/img/shapes/right-title-shape.svg" alt="shape"></span>
            <h2 class="sec-title text-title title-anime__title">Moments At Mission School</h2>
          </div>
        </div>
      </div>
      <div class="row gy-30 mb-30">

<% if (gallery && gallery.length > 0) { %>

  <% gallery.forEach(item => { %>

  <div class="col-xl-4 col-lg-6 col-md-6">

    <div class="gallery-box style2 wow animate__fadeInUp" data-wow-delay="0.30s">

      <div class="gallery-img">

        <img 
          src="/uploads/<%= item.image %>" 
          alt="<%= item.category || 'Gallery Image' %>"
          loading="lazy"
          decoding="async"
        >

        <% if (item.category) { %>
          <a href="#" class="gallery-tag"><%= item.category %></a>
        <% } %>

        <div class="gallery-content">

          <h2 class="gallery-title">
            <%= item.category || 'School Gallery' %>
          </h2>

        </div>

      </div>

    </div>

  </div>

  <% }) %>

<% } else { %>

<div class="col-12 text-center">
  <p>No gallery items available</p>
</div>

<% } %>

</div>
      <% if (totalPages > 1) { %>

      <div class="row justify-content-center wow animate__fadeInUp" data-wow-delay="0.95s">

      <div class="col-auto">

      <div class="vs-pagination">

          <% if(currentPage > 1){ %>
              <a href="/gallery?page=<%= currentPage-1 %>" class="pagi-btn">
                  <i class="fa-solid fa-arrow-left"></i>
              </a>
          <% } %>

          <ul>

          <% for(let i=1;i<=totalPages;i++){ %>

              <li>
                  <a 
                      href="/gallery?page=<%= i %>" 
                      class="<%= currentPage === i ? 'active' : '' %>"
                  >
                      <%= i %>
                  </a>
              </li>

          <% } %>

          </ul>

          <% if(currentPage < totalPages){ %>
              <a href="/gallery?page=<%= currentPage+1 %>" class="pagi-btn active">
                  <i class="fa-solid fa-arrow-right"></i>
              </a>
          <% } %>

      </div>

      </div>
      </div>

      <% } %>
    </div>
  </section>
