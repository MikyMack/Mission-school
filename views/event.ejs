  <section class="events-section space">
    <div class="container">
      <div class="row justify-content-center mb-5">
        <div class="col-xl-8">
          <div class="title-area text-center animation-style1 title-anime">
            <span class="sec-subtitle text-theme title-anime__title">
              <img src="/img/shapes/left-title-shape.svg" alt="shape">
              Upcoming Events
              <img src="/img/shapes/right-title-shape.svg" alt="shape">
            </span>
            <h2 class="sec-title text-title title-anime__title">
              Discover Our <span class="title-highlight text-secondary inline">Exciting Events</span>
            </h2>
          </div>
        </div>
      </div>

      <div class="row g-4">

      <% if (events && events.length > 0) { %>

          <% events.forEach(event => { %>

          <div class="col-lg-4 col-md-6">
              <div class="event-card">

                  <div class="event-image">

                      <img 
                          src="<%= event.image ? '/uploads/' + event.image : '/img/default-event.jpg' %>" 
                          alt="<%= event.title || 'Event Image' %>"
                      >

                      <% if (event.date) { 
                          const d = new Date(event.date);
                          const day = d.getDate();
                          const month = d.toLocaleString('default', { month: 'short' });
                      %>

                      <div class="event-date">
                          <span class="day"><%= day %></span>
                          <span class="month"><%= month %></span>
                      </div>

                      <% } %>

                  </div>

                  <div class="event-content">

                      <div class="event-meta">

                          <% if(event.eventPlace){ %>
                              <span>
                                  <i class="fas fa-map-marker-alt"></i> 
                                  <%= event.eventPlace %>
                              </span>
                          <% } %>

                          <% if(event.coordinatorName){ %>
                              <span>
                                  <i class="fas fa-user"></i> 
                                  <%= event.coordinatorName %>
                              </span>
                          <% } %>

                      </div>

                      <h3 class="event-title">
                          <%= event.title || 'Untitled Event' %>
                      </h3>

                      <p class="event-description">
                          <%= event.description ? event.description.substring(0,120) + '...' : 'No description available.' %>
                      </p>

                  </div>

              </div>
          </div>

          <% }) %>

      <% } else { %>

      <div class="col-12 text-center">
          <p style="font-size:18px;">No events available at the moment.</p>
      </div>

      <% } %>

      </div>

      <!-- Pagination -->
      <% if (totalPages > 1) { %>

      <div class="row justify-content-center wow animate__fadeInUp" data-wow-delay="0.95s">
      <div class="col-auto">

      <div class="vs-pagination">

          <% if (currentPage > 1) { %>
              <a href="/events?page=<%= currentPage-1 %>" class="pagi-btn">
                  <i class="fa-solid fa-arrow-left"></i>
              </a>
          <% } %>

          <ul>

          <% for(let i=1;i<=totalPages;i++){ %>

              <li>
                  <a 
                      href="/events?page=<%= i %>" 
                      class="<%= currentPage === i ? 'active' : '' %>"
                  >
                      <%= i %>
                  </a>
              </li>

          <% } %>

          </ul>

          <% if (currentPage < totalPages) { %>
              <a href="/events?page=<%= currentPage+1 %>" class="pagi-btn active">
                  <i class="fa-solid fa-arrow-right"></i>
              </a>
          <% } %>

      </div>

      </div>
      </div>

      <% } %>
    </div>
  </section>

